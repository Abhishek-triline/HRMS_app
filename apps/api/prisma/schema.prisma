// Nexora HRMS — Prisma schema (v2 — clean refactor)
//
// Per docs/HRMS_Schema_v2_Plan.md:
//   • Every primary key is INT AUTO_INCREMENT (no cuids).
//   • Every status/type/category column is plain INT — no Prisma enums.
//   • Lookup data (roles, employment_types, departments, designations,
//     genders, audit_modules, leave_types) lives in master tables.
//   • All DB column names are snake_case via @map; Prisma field names stay
//     camelCase so application code reads naturally.
//   • No FOREIGN KEY constraints — `relationMode = "prisma"` enforces
//     integrity at the application layer; @relation directives drive
//     Prisma's client-side joins only.
//
// INT-code mappings are frozen — see docs/HRMS_Schema_v2_Plan.md §3 and
// apps/api/src/lib/statusInt.ts. Never re-number; only append.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

// ════════════════════════════════════════════════════════════════════════════
// MASTER / LOOKUP TABLES
// ════════════════════════════════════════════════════════════════════════════

/// Master list of roles.
/// Seed (frozen IDs): 1=Employee, 2=Manager, 3=PayrollOfficer, 4=Admin.
/// status_id: 1=Active, 2=Deprecated.
model Role {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  statusId  Int      @default(1) @map("status_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  employees Employee[]
  @@map("roles")
}

/// Master list of employment types.
/// Seed (frozen IDs): 1=Permanent, 2=Contract, 3=Probation, 4=Intern.
model EmploymentType {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  statusId  Int      @default(1) @map("status_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  employees Employee[]
  @@map("employment_types")
}

/// Master list of departments. Admin can add new ones via the Admin UI.
model Department {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  statusId  Int      @default(1) @map("status_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  employees Employee[]
  @@map("departments")
}

/// Master list of designations / job titles. Admin can add new ones.
model Designation {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  statusId  Int      @default(1) @map("status_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  employees Employee[]
  @@map("designations")
}

/// Master list of genders.
/// Seed (frozen IDs): 1=Male, 2=Female, 3=Other, 4=PreferNotToSay.
model Gender {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  statusId  Int      @default(1) @map("status_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  employees Employee[]
  @@map("genders")
}

/// Master list of audit-log modules.
/// Seed (frozen IDs): 1=auth, 2=employees, 3=leave, 4=payroll, 5=attendance,
/// 6=performance, 7=notifications, 8=audit, 9=configuration.
model AuditModule {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  statusId  Int      @default(1) @map("status_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  auditLogs AuditLog[]
  @@map("audit_modules")
}

/// Master list of leave types.
/// Seed (frozen IDs): 1=Annual, 2=Sick, 3=Casual, 4=Unpaid, 5=Maternity, 6=Paternity.
model LeaveType {
  id                    Int      @id @default(autoincrement())
  name                  String   @unique
  isEventBased          Boolean  @map("is_event_based")
  requiresAdminApproval Boolean  @map("requires_admin_approval")
  carryForwardCap       Int?     @map("carry_forward_cap")
  maxDaysPerEvent       Int?     @map("max_days_per_event")
  statusId              Int      @default(1) @map("status_id")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  quotas        LeaveQuota[]
  balances      LeaveBalance[]
  requests      LeaveRequest[]
  ledgerEntries LeaveBalanceLedger[]
  @@map("leave_types")
}

// ════════════════════════════════════════════════════════════════════════════
// CORE — EMPLOYEES + HIERARCHY
// ════════════════════════════════════════════════════════════════════════════

/// Core employee record. BL-008: code is EMP-YYYY-NNNN and never reused.
/// status_id (§3.1): 1=Active, 2=OnNotice, 3=OnLeave, 4=Inactive, 5=Exited.
model Employee {
  id           Int      @id @default(autoincrement())
  /// BL-008 — unique, never reused, generated transactionally per year
  code         String   @unique
  email        String   @unique
  name         String
  passwordHash String   @map("password_hash")

  // Master FKs — INT columns; no DB-level FK constraints (relationMode=prisma)
  roleId             Int      @map("role_id")
  role               Role     @relation(fields: [roleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  employmentTypeId   Int      @default(1) @map("employment_type_id")
  employmentType     EmploymentType @relation(fields: [employmentTypeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  departmentId       Int?     @map("department_id")
  department         Department? @relation(fields: [departmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  designationId      Int?     @map("designation_id")
  designation        Designation? @relation(fields: [designationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  genderId           Int?     @map("gender_id")
  gender             Gender?  @relation(fields: [genderId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  /// §3.1 status code. Default 4=Inactive (pre-first-login).
  statusId           Int      @default(4) @map("status_id")

  // Optional personal info
  phone        String?
  dateOfBirth  DateTime? @db.Date @map("date_of_birth")

  // Self-relation: reporting manager
  reportingManagerId         Int?      @map("reporting_manager_id")
  reportingManager           Employee? @relation("EmployeeManager", fields: [reportingManagerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reports                    Employee[] @relation("EmployeeManager")
  previousReportingManagerId Int?      @map("previous_reporting_manager_id")

  joinDate          DateTime  @db.Date @map("join_date")
  exitDate          DateTime? @db.Date @map("exit_date")
  mustResetPassword Boolean   @default(false) @map("must_reset_password")

  version           Int       @default(0)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  // Back-references
  sessions                  Session[]
  passwordResetTokens       PasswordResetToken[]
  loginAttempts             LoginAttempt[]
  auditActorEntries         AuditLog[] @relation("AuditActor")
  salaryStructures          SalaryStructure[]
  reportingManagerHistory   ReportingManagerHistory[] @relation("EmployeeHistory")
  managedHistories          ReportingManagerHistory[] @relation("ManagerHistory")
  leaveRequests             LeaveRequest[] @relation("EmployeeLeaveRequests")
  leaveRequestsApproving    LeaveRequest[] @relation("LeaveApprover")
  leaveBalances             LeaveBalance[]
  leaveBalanceLedger        LeaveBalanceLedger[] @relation("EmployeeLedger")
  attendanceRecords         AttendanceRecord[] @relation("EmployeeAttendance")
  regularisations           RegularisationRequest[] @relation("EmployeeRegularisations")
  regularisationsApproving  RegularisationRequest[] @relation("RegularisationApprover")
  lateLedger                AttendanceLateLedger[] @relation("EmployeeLateLedger")
  payrollRunsInitiated      PayrollRun[] @relation("PayrollInitiator")
  payrollRunsFinalised      PayrollRun[] @relation("PayrollFinaliser")
  payrollRunsReversed       PayrollRun[] @relation("PayrollReverser")
  payslips                  Payslip[] @relation("EmployeePayslips")
  idempotencyKeys           IdempotencyKey[] @relation("EmployeeIdempotencyKeys")
  performanceCyclesCreated  PerformanceCycle[] @relation("CycleCreatedBy")
  performanceCyclesClosed   PerformanceCycle[] @relation("CycleClosedBy")
  reviewsAsEmployee         PerformanceReview[] @relation("ReviewEmployee")
  reviewsAsManager          PerformanceReview[] @relation("ReviewManager")
  reviewsAsPreviousManager  PerformanceReview[] @relation("ReviewPreviousManager")
  notifications             Notification[] @relation("EmployeeNotifications")
  leaveEncashments          LeaveEncashment[] @relation("EmployeeEncashments")
  encashmentsApproving      LeaveEncashment[] @relation("EncashmentApprover")

  @@index([email])
  @@index([reportingManagerId])
  @@index([previousReportingManagerId])
  @@index([roleId])
  @@index([employmentTypeId])
  @@index([departmentId])
  @@index([designationId])
  @@index([genderId])
  @@index([statusId])
  @@map("employees")
}

/// Salary structure history. One row per change; active = latest effectiveFrom <= today.
/// BL-030: salary edits apply from the next payroll run; old payslips immutable.
model SalaryStructure {
  id              Int      @id @default(autoincrement())
  employeeId      Int      @map("employee_id")
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  basicPaise      Int      @map("basic_paise")
  allowancesPaise Int      @map("allowances_paise")
  effectiveFrom   DateTime @db.Date @map("effective_from")
  createdAt       DateTime @default(now()) @map("created_at")
  version         Int      @default(0)

  // Optional component breakdown
  hraPaise        Int?     @map("hra_paise")
  transportPaise  Int?     @map("transport_paise")
  otherPaise      Int?     @map("other_paise")
  daPaise         Int?     @map("da_paise")

  @@index([employeeId, effectiveFrom(sort: Desc)])
  @@map("salary_structures")
}

/// Audit trail for reporting-manager assignments. BL-007: never deleted.
/// reason_id (§3.8 history): 1=Initial, 2=Reassigned, 3=Exited.
model ReportingManagerHistory {
  id         Int       @id @default(autoincrement())
  employeeId Int       @map("employee_id")
  employee   Employee  @relation("EmployeeHistory", fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  managerId  Int?      @map("manager_id")
  manager    Employee? @relation("ManagerHistory", fields: [managerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  fromDate   DateTime  @db.Date @map("from_date")
  toDate     DateTime? @db.Date @map("to_date")
  reasonId   Int       @map("reason_id")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([employeeId, fromDate(sort: Desc)])
  @@index([managerId, toDate])
  @@map("reporting_manager_history")
}

/// Session row. iron-session data maps to this.
model Session {
  id         Int       @id @default(autoincrement())
  /// Public session token returned in the cookie (random hex).
  token      String    @unique
  employeeId Int       @map("employee_id")
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ip         String?
  userAgent  String?   @db.Text @map("user_agent")
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([employeeId])
  @@index([expiresAt])
  @@map("sessions")
}

/// Login attempt log — feeds the lockout check.
model LoginAttempt {
  id         Int       @id @default(autoincrement())
  email      String
  ip         String
  success    Boolean
  employeeId Int?      @map("employee_id")
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([email, createdAt])
  @@index([ip, createdAt])
  @@map("login_attempts")
}

/// One-shot token used for first-login and password-reset flows.
/// purpose_id (§3.8): 1=FirstLogin, 2=ResetPassword.
model PasswordResetToken {
  id         Int       @id @default(autoincrement())
  tokenHash  String    @unique @map("token_hash")
  employeeId Int       @map("employee_id")
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  purposeId  Int       @map("purpose_id")
  expiresAt  DateTime  @map("expires_at")
  usedAt     DateTime? @map("used_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([employeeId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// ════════════════════════════════════════════════════════════════════════════
// LEAVE
// ════════════════════════════════════════════════════════════════════════════

/// Leave quotas — days per year per leave type per employment type.
model LeaveQuota {
  id               Int        @id @default(autoincrement())
  leaveTypeId      Int        @map("leave_type_id")
  leaveType        LeaveType  @relation(fields: [leaveTypeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  employmentTypeId Int        @map("employment_type_id")
  daysPerYear      Int        @map("days_per_year")

  @@unique([leaveTypeId, employmentTypeId])
  @@map("leave_quotas")
}

/// Running balance per employee / leave type / year. Refreshed by carry-forward cron.
model LeaveBalance {
  id            Int       @id @default(autoincrement())
  employeeId    Int       @map("employee_id")
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  leaveTypeId   Int       @map("leave_type_id")
  leaveType     LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  year          Int
  daysRemaining Int       @default(0) @map("days_remaining")
  daysUsed      Int       @default(0) @map("days_used")
  /// Days encashed this year (BL-LE-06). Separate from daysUsed.
  daysEncashed  Int       @default(0) @map("days_encashed")
  version       Int       @default(0)

  @@unique([employeeId, leaveTypeId, year])
  @@index([employeeId, year])
  @@map("leave_balances")
}

/// Append-only ledger of every balance mutation. BL-047 immutable.
/// reason_id (§3.2): 1=Initial, 2=Approval, 3=Cancellation, 4=CarryForward, 5=Adjustment, 6=LateMarkPenalty.
model LeaveBalanceLedger {
  id               Int       @id @default(autoincrement())
  employeeId       Int       @map("employee_id")
  employee         Employee  @relation("EmployeeLedger", fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  leaveTypeId      Int       @map("leave_type_id")
  leaveType        LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  year             Int
  delta            Int
  reasonId         Int       @map("reason_id")
  relatedRequestId Int?      @map("related_request_id")
  createdBy        Int?      @map("created_by")
  createdAt        DateTime  @default(now()) @map("created_at")

  @@index([employeeId, year, createdAt])
  @@map("leave_balance_ledger")
}

/// Per-year counter for L-YYYY-NNNN codes.
model LeaveCodeCounter {
  year   Int @id
  number Int @default(0)
  @@map("leave_code_counters")
}

/// Per-year counter for LE-YYYY-NNNN encashment codes.
model EncashmentCodeCounter {
  year   Int @id
  number Int @default(0)
  @@map("encashment_code_counters")
}

/// Leave request.
/// status_id (§3.2): 1=Pending, 2=Approved, 3=Rejected, 4=Cancelled, 5=Escalated.
/// routed_to_id (§3.2): 1=Manager, 2=Admin.
model LeaveRequest {
  id                  Int       @id @default(autoincrement())
  code                String    @unique
  employeeId          Int       @map("employee_id")
  employee            Employee  @relation("EmployeeLeaveRequests", fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  leaveTypeId         Int       @map("leave_type_id")
  leaveType           LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  fromDate            DateTime  @db.Date @map("from_date")
  toDate              DateTime  @db.Date @map("to_date")
  days                Int
  reason              String    @db.Text
  statusId            Int       @default(1) @map("status_id")
  routedToId          Int       @map("routed_to_id")
  approverId          Int?      @map("approver_id")
  approver            Employee? @relation("LeaveApprover", fields: [approverId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  decidedAt           DateTime? @map("decided_at")
  decidedBy           Int?      @map("decided_by")
  decisionNote        String?   @db.Text @map("decision_note")
  escalatedAt         DateTime? @map("escalated_at")
  cancelledAt         DateTime? @map("cancelled_at")
  cancelledBy         Int?      @map("cancelled_by")
  cancelledAfterStart Boolean   @default(false) @map("cancelled_after_start")
  deductedDays        Int       @default(0) @map("deducted_days")
  restoredDays        Int       @default(0) @map("restored_days")
  version             Int       @default(0)
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@index([employeeId, statusId])
  @@index([approverId, statusId])
  @@index([statusId, escalatedAt])
  @@map("leave_requests")
}

// ════════════════════════════════════════════════════════════════════════════
// ATTENDANCE + REGULARISATION
// ════════════════════════════════════════════════════════════════════════════

/// Per-month late-mark count per employee. BL-028 penalty driver.
model AttendanceLateLedger {
  id         Int      @id @default(autoincrement())
  employeeId Int      @map("employee_id")
  employee   Employee @relation("EmployeeLateLedger", fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  year       Int
  month      Int
  count      Int      @default(0)
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([employeeId, year, month])
  @@map("attendance_late_ledger")
}

/// Attendance record. BL-023: one row per active employee per day.
/// status_id (§3.4): 1=Present, 2=Absent, 3=OnLeave, 4=WeeklyOff, 5=Holiday.
/// source_id (§3.4): 1=system, 2=regularisation.
model AttendanceRecord {
  id                 Int       @id @default(autoincrement())
  employeeId         Int       @map("employee_id")
  employee           Employee  @relation("EmployeeAttendance", fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  date               DateTime  @db.Date
  statusId           Int       @map("status_id")
  checkInTime        DateTime? @map("check_in_time")
  checkOutTime       DateTime? @map("check_out_time")
  hoursWorkedMinutes Int?      @map("hours_worked_minutes")
  late               Boolean   @default(false)
  lateMonthCount     Int       @default(0) @map("late_month_count")
  lopApplied         Boolean   @default(false) @map("lop_applied")
  sourceId           Int       @map("source_id")
  regularisationId   Int?      @map("regularisation_id")
  regularisation     RegularisationRequest? @relation(fields: [regularisationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  version            Int       @default(0)
  createdAt          DateTime  @default(now()) @map("created_at")

  @@unique([employeeId, date, sourceId])
  @@index([employeeId, date])
  @@index([date, statusId])
  @@map("attendance_records")
}

/// Year-keyed counter for R-YYYY-NNNN regularisation codes.
model RegCodeCounter {
  year   Int @id
  number Int @default(0)
  @@map("reg_code_counters")
}

/// Regularisation request.
/// status_id (§3.4): 1=Pending, 2=Approved, 3=Rejected.
/// routed_to_id (§3.4): 1=Manager, 2=Admin.
model RegularisationRequest {
  id                Int       @id @default(autoincrement())
  code              String    @unique
  employeeId        Int       @map("employee_id")
  employee          Employee  @relation("EmployeeRegularisations", fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  date              DateTime  @db.Date
  proposedCheckIn   DateTime? @map("proposed_check_in")
  proposedCheckOut  DateTime? @map("proposed_check_out")
  reason            String    @db.Text
  statusId          Int       @default(1) @map("status_id")
  routedToId        Int       @map("routed_to_id")
  ageDaysAtSubmit   Int       @map("age_days_at_submit")
  approverId        Int?      @map("approver_id")
  approver          Employee? @relation("RegularisationApprover", fields: [approverId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  decidedAt         DateTime? @map("decided_at")
  decidedBy         Int?      @map("decided_by")
  decisionNote      String?   @db.Text @map("decision_note")
  correctedRecordId Int?      @unique @map("corrected_record_id")
  version           Int       @default(0)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  attendanceRecords AttendanceRecord[]

  @@index([employeeId, statusId])
  @@index([approverId, statusId])
  @@map("regularisation_requests")
}

/// Public holiday. BL-026: workdays exclude these.
model Holiday {
  id        Int      @id @default(autoincrement())
  date      DateTime @db.Date
  name      String
  year      Int
  /// Optional source label (manual / gazette / custom) — free text.
  source    String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([date])
  @@index([year])
  @@map("holidays")
}

// ════════════════════════════════════════════════════════════════════════════
// PAYROLL
// ════════════════════════════════════════════════════════════════════════════

/// Year-month counter for RUN-YYYY-MM-NN codes.
model PayrollCodeCounter {
  year   Int
  month  Int
  number Int @default(0)
  @@id([year, month])
  @@map("payroll_code_counters")
}

/// Payroll run. status_id (§3.5): 1=Draft, 2=Review, 3=Finalised, 4=Reversed.
model PayrollRun {
  id              Int       @id @default(autoincrement())
  code            String    @unique
  month           Int
  year            Int
  statusId        Int       @default(2) @map("status_id")
  workingDays     Int       @map("working_days")
  periodStart     DateTime  @db.Date @map("period_start")
  periodEnd       DateTime  @db.Date @map("period_end")
  initiatedBy     Int       @map("initiated_by")
  initiator       Employee  @relation("PayrollInitiator", fields: [initiatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  initiatedAt     DateTime  @default(now()) @map("initiated_at")
  finalisedBy     Int?      @map("finalised_by")
  finaliser       Employee? @relation("PayrollFinaliser", fields: [finalisedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  finalisedAt     DateTime? @map("finalised_at")
  reversedBy      Int?      @map("reversed_by")
  reverser        Employee? @relation("PayrollReverser", fields: [reversedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reversedAt      DateTime? @map("reversed_at")
  reversalReason  String?   @db.Text @map("reversal_reason")
  reversalOfRunId Int?      @map("reversal_of_run_id")
  version         Int       @default(0)

  payslips Payslip[]

  @@unique([month, year, reversalOfRunId])
  @@index([statusId, year, month])
  @@map("payroll_runs")
}

/// Payslip. status_id (§3.5, same as PayrollRun): 1=Draft, 2=Review, 3=Finalised, 4=Reversed.
model Payslip {
  id                   Int       @id @default(autoincrement())
  code                 String    @unique
  runId                Int       @map("run_id")
  run                  PayrollRun @relation(fields: [runId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  employeeId           Int       @map("employee_id")
  employee             Employee  @relation("EmployeePayslips", fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  month                Int
  year                 Int
  statusId             Int       @default(2) @map("status_id")
  periodStart          DateTime  @db.Date @map("period_start")
  periodEnd            DateTime  @db.Date @map("period_end")
  workingDays          Int       @map("working_days")
  daysWorked           Int       @map("days_worked")
  lopDays              Int       @default(0) @map("lop_days")
  basicPaise           Int       @map("basic_paise")
  allowancesPaise      Int       @map("allowances_paise")
  grossPaise           Int       @map("gross_paise")
  lopDeductionPaise    Int       @default(0) @map("lop_deduction_paise")
  referenceTaxPaise    Int       @default(0) @map("reference_tax_paise")
  finalTaxPaise        Int       @default(0) @map("final_tax_paise")
  otherDeductionsPaise Int       @default(0) @map("other_deductions_paise")
  netPayPaise          Int       @map("net_pay_paise")
  encashmentDays       Int       @default(0) @map("encashment_days")
  encashmentPaise      Int       @default(0) @map("encashment_paise")
  encashmentId         Int?      @unique @map("encashment_id")
  encashment           LeaveEncashment? @relation("PayslipEncashment", fields: [encashmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  finalisedAt          DateTime? @map("finalised_at")
  reversalOfPayslipId  Int?      @unique @map("reversal_of_payslip_id")
  reversedByPayslipId  Int?      @unique @map("reversed_by_payslip_id")
  reversedByPayslip    Payslip?  @relation("PayslipReversedBy", fields: [reversedByPayslipId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reversedByPayslipRef Payslip[] @relation("PayslipReversedBy")
  version              Int       @default(0)
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  @@unique([runId, employeeId])
  @@index([employeeId, year, month])
  @@map("payslips")
}

// ════════════════════════════════════════════════════════════════════════════
// LEAVE ENCASHMENT
// ════════════════════════════════════════════════════════════════════════════

/// Leave encashment request.
/// status_id (§3.3): 1=Pending, 2=ManagerApproved, 3=AdminFinalised, 4=Paid, 5=Rejected, 6=Cancelled.
/// routed_to_id (§3.3): 1=Manager, 2=Admin.
model LeaveEncashment {
  id              Int       @id @default(autoincrement())
  code            String    @unique
  employeeId      Int       @map("employee_id")
  employee        Employee  @relation("EmployeeEncashments", fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  year            Int
  daysRequested   Int       @map("days_requested")
  daysApproved    Int?      @map("days_approved")
  ratePerDayPaise Int?      @map("rate_per_day_paise")
  amountPaise     Int?      @map("amount_paise")
  statusId        Int       @default(1) @map("status_id")
  routedToId      Int       @map("routed_to_id")
  approverId      Int?      @map("approver_id")
  approver        Employee? @relation("EncashmentApprover", fields: [approverId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  decidedAt       DateTime? @map("decided_at")
  decidedBy       Int?      @map("decided_by")
  decisionNote    String?   @db.Text @map("decision_note")
  escalatedAt     DateTime? @map("escalated_at")
  paidAt          DateTime? @map("paid_at")
  cancelledAt     DateTime? @map("cancelled_at")
  cancelledBy     Int?      @map("cancelled_by")
  version         Int       @default(0)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  paidInPayslip   Payslip[] @relation("PayslipEncashment")

  @@index([employeeId, year, statusId])
  @@map("leave_encashments")
}

// ════════════════════════════════════════════════════════════════════════════
// PERFORMANCE
// ════════════════════════════════════════════════════════════════════════════

/// Performance cycle.
/// status_id (§3.6): 1=Open, 2=SelfReview, 3=ManagerReview, 4=Closed.
model PerformanceCycle {
  id                    Int       @id @default(autoincrement())
  code                  String    @unique
  fyStart               DateTime  @db.Date @map("fy_start")
  fyEnd                 DateTime  @db.Date @map("fy_end")
  statusId              Int       @default(1) @map("status_id")
  selfReviewDeadline    DateTime  @db.Date @map("self_review_deadline")
  managerReviewDeadline DateTime  @db.Date @map("manager_review_deadline")
  closedAt              DateTime? @map("closed_at")
  closedBy              Int?      @map("closed_by")
  closer                Employee? @relation("CycleClosedBy", fields: [closedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdBy             Int       @map("created_by")
  creator               Employee  @relation("CycleCreatedBy", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  version               Int       @default(0)

  reviews PerformanceReview[]

  @@map("performance_cycles")
}

/// Performance review row per (cycle, employee).
model PerformanceReview {
  id                  Int       @id @default(autoincrement())
  cycleId             Int       @map("cycle_id")
  cycle               PerformanceCycle @relation(fields: [cycleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  employeeId          Int       @map("employee_id")
  employee            Employee  @relation("ReviewEmployee", fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  managerId           Int?      @map("manager_id")
  manager             Employee? @relation("ReviewManager", fields: [managerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  previousManagerId   Int?      @map("previous_manager_id")
  previousManager     Employee? @relation("ReviewPreviousManager", fields: [previousManagerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  selfRating          Int?      @map("self_rating")
  selfNote            String?   @db.Text @map("self_note")
  managerRating       Int?      @map("manager_rating")
  managerNote         String?   @db.Text @map("manager_note")
  managerOverrodeSelf Boolean   @default(false) @map("manager_overrode_self")
  finalRating         Int?      @map("final_rating")
  lockedAt            DateTime? @map("locked_at")
  version             Int       @default(0)
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  goals Goal[]

  @@unique([cycleId, employeeId])
  @@index([employeeId])
  @@map("performance_reviews")
}

/// Goal under a review.
/// outcome_id (§3.6): 1=Pending, 2=Met, 3=Partial, 4=Missed.
model Goal {
  id                 Int       @id @default(autoincrement())
  reviewId           Int       @map("review_id")
  review             PerformanceReview @relation(fields: [reviewId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  text               String    @db.Text
  outcomeId          Int       @default(1) @map("outcome_id")
  proposedByEmployee Boolean   @default(false) @map("proposed_by_employee")
  version            Int       @default(0)
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@index([reviewId])
  @@map("goals")
}

// ════════════════════════════════════════════════════════════════════════════
// NOTIFICATIONS + AUDIT + CONFIGURATION
// ════════════════════════════════════════════════════════════════════════════

/// Notification feed item.
/// category_id (§3.7): 1=Leave, 2=Attendance, 3=Payroll, 4=Performance, 5=Status,
/// 6=Configuration, 7=Auth, 8=System.
model Notification {
  id          Int       @id @default(autoincrement())
  recipientId Int       @map("recipient_id")
  recipient   Employee  @relation("EmployeeNotifications", fields: [recipientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  categoryId  Int       @map("category_id")
  title       String
  body        String    @db.Text
  link        String?
  unread      Boolean   @default(true)
  auditLogId  Int?      @map("audit_log_id")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([recipientId, unread, createdAt(sort: Desc)])
  @@index([createdAt])
  @@map("notifications")
}

/// Append-only audit log. BL-047 enforced by REVOKE UPDATE/DELETE post-migration.
/// target_type_id (§3.9): 1=Employee, 2=LeaveRequest, 3=LeaveEncashment, 4=AttendanceRecord,
/// 5=RegularisationRequest, 6=PayrollRun, 7=Payslip, 8=PerformanceCycle,
/// 9=PerformanceReview, 10=Goal, 11=Configuration, 12=SalaryStructure, 13=Holiday,
/// 14=Notification.
/// actor_role_id (§3.9): 1=Employee, 2=Manager, 3=PayrollOfficer, 4=Admin, 99=unknown, 100=system.
/// module_id: FK to audit_modules master.
model AuditLog {
  id            Int       @id @default(autoincrement())
  actorId       Int?      @map("actor_id")
  actor         Employee? @relation("AuditActor", fields: [actorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  actorRoleId   Int       @map("actor_role_id")
  actorIp       String?   @map("actor_ip")
  action        String
  targetTypeId  Int?      @map("target_type_id")
  targetId      Int?      @map("target_id")
  moduleId      Int       @map("module_id")
  module        AuditModule @relation(fields: [moduleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  before        Json?
  after         Json?
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@index([targetTypeId, targetId])
  @@index([moduleId])
  @@map("audit_log")
}

/// Key/value configuration store. PK is the key string (semantic lookup).
model Configuration {
  key       String   @id
  value     Json
  updatedBy String?  @map("updated_by")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@map("configurations")
}

/// Idempotency key store for guarded mutation endpoints.
model IdempotencyKey {
  id               Int       @id @default(autoincrement())
  key              String    @unique
  employeeId       Int       @map("employee_id")
  employee         Employee  @relation("EmployeeIdempotencyKeys", fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  endpoint         String
  responseSnapshot Json      @map("response_snapshot")
  createdAt        DateTime  @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("idempotency_keys")
}
