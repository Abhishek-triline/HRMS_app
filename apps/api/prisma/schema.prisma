// Nexora HRMS — Prisma schema (Phase 0)
// BL-047 enforcement: REVOKE UPDATE, DELETE on audit_log runs as raw SQL
// after migration (see migration script comment).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  Employee
  Manager
  PayrollOfficer
  Admin
}

/// BL-022: employment type drives leave quotas and proration rules.
enum EmploymentType {
  Permanent
  Contract
  Intern
  Probation
}

/// Reason stored on ReportingManagerHistory rows when a row is closed.
enum HistoryReason {
  Initial
  Reassigned
  Exited
}

/// BL-006: Active / OnNotice / Exited are Admin-controlled.
/// OnLeave is system-set on leave approval start, reverted on end.
/// Inactive is the pre-first-login state.
enum EmployeeStatus {
  Active
  OnNotice
  Exited
  OnLeave
  Inactive
}

enum TokenPurpose {
  FirstLogin
  ResetPassword
}

// ── Tables ───────────────────────────────────────────────────────────────────

/// Core employee record. BL-008: code is EMP-YYYY-NNNN and never reused.
model Employee {
  id                String         @id @default(cuid())
  /// BL-008 — unique, never reused, generated transactionally per year
  code              String         @unique
  email             String         @unique
  /// stored as first+last or full name
  name              String
  passwordHash      String
  role              Role
  status            EmployeeStatus @default(Inactive)
  /// Employment type drives leave quotas and proration (BL-022a)
  employmentType    EmploymentType @default(Permanent)
  department        String?
  designation       String?
  reportingManagerId String?
  reportingManager  Employee?      @relation("EmployeeManager", fields: [reportingManagerId], references: [id])
  reports           Employee[]     @relation("EmployeeManager")
  /// The most recent prior manager id — fast lookup for past-team queries (BL-022a)
  previousReportingManagerId String?
  joinDate          DateTime       @db.Date
  exitDate          DateTime?      @db.Date
  /// UC-FL-01: forces password reset on first login
  mustResetPassword Boolean        @default(false)
  /// Optimistic concurrency token (BL-034 applies to all mutable resources)
  version           Int            @default(0)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  sessions              Session[]
  passwordResetTokens   PasswordResetToken[]
  loginAttempts         LoginAttempt[]
  auditActorEntries     AuditLog[]           @relation("AuditActor")
  salaryStructures      SalaryStructure[]
  reportingManagerHistory ReportingManagerHistory[] @relation("EmployeeHistory")
  managedHistories        ReportingManagerHistory[] @relation("ManagerHistory")
  // Phase 2 — Leave
  leaveRequests           LeaveRequest[]     @relation("EmployeeLeaveRequests")
  leaveRequestsApproving  LeaveRequest[]     @relation("LeaveApprover")
  leaveBalances           LeaveBalance[]
  leaveBalanceLedger      LeaveBalanceLedger[] @relation("EmployeeLedger")
  // Phase 3 — Attendance & Regularisation
  attendanceRecords       AttendanceRecord[]  @relation("EmployeeAttendance")
  regularisations         RegularisationRequest[] @relation("EmployeeRegularisations")
  regularisationsApproving RegularisationRequest[] @relation("RegularisationApprover")
  lateLedger              AttendanceLateLedger[] @relation("EmployeeLateLedger")
  // Phase 4 — Payroll
  payrollRunsInitiated    PayrollRun[]           @relation("PayrollInitiator")
  payrollRunsFinalised    PayrollRun[]           @relation("PayrollFinaliser")
  payrollRunsReversed     PayrollRun[]           @relation("PayrollReverser")
  payslips                Payslip[]              @relation("EmployeePayslips")
  idempotencyKeys         IdempotencyKey[]       @relation("EmployeeIdempotencyKeys")
  // Phase 5 — Performance Reviews
  performanceCyclesCreated  PerformanceCycle[]   @relation("CycleCreatedBy")
  performanceCyclesClosed   PerformanceCycle[]   @relation("CycleClosedBy")
  reviewsAsEmployee         PerformanceReview[]  @relation("ReviewEmployee")
  reviewsAsManager          PerformanceReview[]  @relation("ReviewManager")
  reviewsAsPreviousManager  PerformanceReview[]  @relation("ReviewPreviousManager")
  // Phase 6 — Notifications
  notifications             Notification[]       @relation("EmployeeNotifications")

  @@index([email])
  @@index([reportingManagerId])
  @@index([previousReportingManagerId])
  @@map("employees")
}

/// Salary structure history. One row per change; active = latest effectiveFrom <= today.
/// BL-030: salary edits apply from the next payroll run only; old payslips are immutable.
model SalaryStructure {
  id              String   @id @default(cuid())
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  basicPaise      Int      /// stored as integer paise to avoid float drift
  allowancesPaise Int      /// sum of HRA + special + transport, etc.
  effectiveFrom   DateTime @db.Date
  createdAt       DateTime @default(now())
  /// Optimistic concurrency token
  version         Int      @default(0)

  @@index([employeeId, effectiveFrom(sort: Desc)])
  @@map("salary_structures")
}

/// Audit trail for reporting-manager assignments. BL-007: never deleted.
/// Insert Initial on employee creation; close row and insert new row on reassign.
model ReportingManagerHistory {
  id         String        @id @default(cuid())
  employeeId String
  employee   Employee      @relation("EmployeeHistory", fields: [employeeId], references: [id], onDelete: Cascade)
  managerId  String?
  manager    Employee?     @relation("ManagerHistory", fields: [managerId], references: [id], onDelete: SetNull)
  fromDate   DateTime      @db.Date
  /// null means currently open (this is the active assignment)
  toDate     DateTime?     @db.Date
  reason     HistoryReason
  createdAt  DateTime      @default(now())

  @@index([employeeId, fromDate(sort: Desc)])
  @@index([managerId, toDate])
  @@map("reporting_manager_history")
}

/// Session row. iron-session data maps to this.
/// Sliding expiry: 12 h default, 30 days if rememberMe.
model Session {
  id          String    @id @default(cuid())
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  ip          String?
  userAgent   String?   @db.Text
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  @@index([employeeId, expiresAt])
  @@map("sessions")
}

/// Single-use password reset / first-login token.
/// Raw token is sent over email; only the hash is stored (BL-047).
model PasswordResetToken {
  id          String       @id @default(cuid())
  employeeId  String
  employee    Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  tokenHash   String       @unique
  purpose     TokenPurpose
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime     @default(now())

  @@index([tokenHash])
  @@map("password_reset_tokens")
}

/// Login attempt log — used for 5-strikes-in-15-min lockout.
model LoginAttempt {
  id         String    @id @default(cuid())
  email      String
  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  ip         String
  success    Boolean
  createdAt  DateTime  @default(now())

  @@index([email])
  @@index([email, ip, createdAt])
  @@map("login_attempts")
}

/// Append-only audit log. BL-047 / BL-048.
/// DB enforces append-only via REVOKE UPDATE, DELETE (see migration).
/// id is a ULID (generated application-side for monotonic ordering).
model AuditLog {
  id          String   @id // ULID generated by application
  actorId     String?
  actor       Employee? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  actorRole   String
  actorIp     String?
  action      String   // e.g. "auth.login.success"
  targetType  String?
  targetId    String?
  module      String
  before      Json?
  after       Json?
  createdAt   DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@index([targetType, targetId])
  @@map("audit_log")
}

/// System configuration (A-19 and related). Key-value store.
/// Seeded with all configurable defaults on first run.
model Configuration {
  key       String   @id
  value     Json
  updatedBy String?
  updatedAt DateTime @updatedAt

  @@map("configuration")
}

// ── Phase 2 — Leave Management ───────────────────────────────────────────────

/// BL-011 / BL-015 / BL-016: Leave type definitions.
/// name is validated as one of the 6 canonical types at the application layer (zod).
/// isEventBased=true for Maternity/Paternity (no annual accrual).
model LeaveType {
  id                    String   @id @default(cuid())
  name                  String   @unique   // 'Annual'|'Sick'|'Casual'|'Unpaid'|'Maternity'|'Paternity'
  isEventBased          Boolean
  requiresAdminApproval Boolean
  /// Annual + Casual carry forward; Sick/Unpaid/event-based = 0 or null
  carryForwardCap       Int?
  /// Maternity = 182 days (26w), Paternity = 10 days; null for accrual types
  maxDaysPerEvent       Int?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  quotas     LeaveQuota[]
  balances   LeaveBalance[]
  requests   LeaveRequest[]
  ledger     LeaveBalanceLedger[]

  @@map("leave_types")
}

/// Per-employment-type entitlement for each accrual leave type.
/// Maternity/Paternity have no quota rows (event-based, no annual limit).
model LeaveQuota {
  id              String         @id @default(cuid())
  leaveTypeId     String
  leaveType       LeaveType      @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  employmentType  EmploymentType
  daysPerYear     Int

  @@unique([leaveTypeId, employmentType])
  @@index([leaveTypeId])
  @@map("leave_quotas")
}

/// Per-employee per-year balance snapshot (BL-021).
/// version for optimistic concurrency on balance mutations.
/// daysUsed tracks lifetime usage for event-based types in a given year.
model LeaveBalance {
  id            String    @id @default(cuid())
  employeeId    String
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId   String
  leaveType     LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  year          Int       // calendar year
  daysRemaining Int       @default(0)
  daysUsed      Int       @default(0)  // running tally; for event-based: lifetime used this year
  version       Int       @default(0)

  @@unique([employeeId, leaveTypeId, year])
  @@index([employeeId, year])
  @@map("leave_balances")
}

/// Tracks pending + resolved leave requests. BL-009 / BL-019 / BL-020 / BL-021.
model LeaveRequest {
  id                 String              @id @default(cuid())
  /// Format: L-YYYY-NNNN (same pattern as EMP code)
  code               String              @unique
  employeeId         String
  employee           Employee            @relation("EmployeeLeaveRequests", fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId        String
  leaveType          LeaveType           @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)
  fromDate           DateTime            @db.Date
  toDate             DateTime            @db.Date
  days               Int                 // server-computed inclusive count (BL-011)
  reason             String              @db.Text
  status             LeaveRequestStatus  @default(Pending)
  routedTo           RoutedTo
  /// The current approver (Manager or Admin). Null after final decision.
  approverId         String?
  approver           Employee?           @relation("LeaveApprover", fields: [approverId], references: [id], onDelete: SetNull)
  decidedAt          DateTime?
  decidedBy          String?             // employee id of the decision-maker
  decisionNote       String?             @db.Text
  escalatedAt        DateTime?           // set by the hourly cron (BL-018)
  cancelledAt        DateTime?
  cancelledBy        String?
  /// BL-020: true when cancellation happens on/after fromDate
  cancelledAfterStart Boolean            @default(false)
  /// Balance deduction recorded on approval (BL-021); 0 until approved
  deductedDays       Int                 @default(0)
  /// Days restored on cancellation (BL-020)
  restoredDays       Int                 @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  version            Int                 @default(0)

  ledgerEntries      LeaveBalanceLedger[]

  @@index([employeeId, fromDate])
  @@index([approverId, status])
  @@index([status, escalatedAt])
  @@map("leave_requests")
}

/// Append-only ledger — every balance change is a row (BL-021 traceability).
/// Reconstruct the balance at any point by summing delta for (employeeId, leaveTypeId, year).
model LeaveBalanceLedger {
  id               String        @id @default(cuid())
  employeeId       String
  employee         Employee      @relation("EmployeeLedger", fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId      String
  leaveType        LeaveType     @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  year             Int
  /// Positive = grant; negative = deduction (full days only, BL-011)
  delta            Int
  reason           LedgerReason
  /// The leave request that triggered this entry (null for adjustments/carry-forward)
  relatedRequestId String?
  relatedRequest   LeaveRequest? @relation(fields: [relatedRequestId], references: [id], onDelete: SetNull)
  createdBy        String?       // actorId; null for system/cron
  createdAt        DateTime      @default(now())

  @@index([employeeId, leaveTypeId, year])
  @@index([relatedRequestId])
  @@map("leave_balance_ledger")
}

/// Counter table for generating L-YYYY-NNNN codes — same pattern as EMP code.
model LeaveCodeCounter {
  year    Int @id
  lastSeq Int @default(0)

  @@map("leave_code_counters")
}

// ── Leave enums ──────────────────────────────────────────────────────────────

enum LeaveRequestStatus {
  Pending
  Approved
  Rejected
  Cancelled
  Escalated
}

enum RoutedTo {
  Manager
  Admin
}

enum LedgerReason {
  Approval
  Cancellation
  CarryForward
  Adjustment
  Initial
  LateMarkPenalty
}

// ── Phase 3 — Attendance & Regularisation ────────────────────────────────────

/// BL-026: Status derivation priority: OnLeave > WeeklyOff/Holiday > Present > Absent.
/// Stored without hyphens; mapped to contract enum (On-Leave, Weekly-Off) at boundary.
enum AttendanceStatus {
  Present
  Absent
  OnLeave
  WeeklyOff
  Holiday
}

/// BL-007: system = original midnight row; regularisation = corrected overlay row.
/// BL-007 mandates: NEVER delete rows. Corrections append a new row.
enum AttendanceSource {
  system
  regularisation
}

/// Regularisation request status — matches contract RegStatusSchema.
enum RegStatusDb {
  Pending
  Approved
  Rejected
}

/// Regularisation routing — matches contract RegRoutedToSchema.
enum RegRoutedToDb {
  Manager
  Admin
}

/// Attendance record. BL-023: one row per active employee per day (default Absent).
/// BL-007: rows are NEVER deleted. Regularisation corrections add a new row.
/// UNIQUE (employeeId, date, source) so the system row and regularisation overlay coexist.
model AttendanceRecord {
  id                 String            @id @default(cuid())
  employeeId         String
  employee           Employee          @relation("EmployeeAttendance", fields: [employeeId], references: [id], onDelete: Cascade)
  date               DateTime          @db.Date
  status             AttendanceStatus
  checkInTime        DateTime?
  checkOutTime       DateTime?
  /// Server-computed: (checkOutTime − checkInTime) in minutes. BL-025.
  hoursWorkedMinutes Int?
  /// BL-027: true when checkInTime > configured LATE_THRESHOLD.
  late               Boolean           @default(false)
  /// Running count of late marks in the calendar month at the time this row was last written.
  lateMonthCount     Int               @default(0)
  /// True when this Absent day incurs LOP at payroll time.
  lopApplied         Boolean           @default(false)
  /// BL-007: system = midnight-generated; regularisation = approved correction overlay.
  source             AttendanceSource
  /// Set when source = regularisation — links to the approving RegularisationRequest.
  regularisationId   String?
  regularisation     RegularisationRequest? @relation("AttendanceCorrection", fields: [regularisationId], references: [id], onDelete: SetNull)
  createdAt          DateTime          @default(now())
  /// Optimistic concurrency token (BL-034).
  version            Int               @default(0)

  @@unique([employeeId, date, source])
  @@index([employeeId, date])
  @@index([date, status])
  @@map("attendance_records")
}

/// Regularisation request. BL-029: ≤7 days → Manager; >7 days → Admin.
/// BL-010: cannot overlap an approved leave on the same date.
model RegularisationRequest {
  id                 String          @id @default(cuid())
  /// Format: R-YYYY-NNNN
  code               String          @unique
  employeeId         String
  employee           Employee        @relation("EmployeeRegularisations", fields: [employeeId], references: [id], onDelete: Cascade)
  /// The date being corrected (always in the past).
  date               DateTime        @db.Date
  proposedCheckIn    DateTime?
  proposedCheckOut   DateTime?
  reason             String          @db.Text
  status             RegStatusDb     @default(Pending)
  /// BL-029: age-based routing (≤7d → Manager, >7d → Admin).
  routedTo           RegRoutedToDb
  /// Captured at submit time — snapshot for the audit trail.
  ageDaysAtSubmit    Int
  /// Current owner of the approval queue.
  approverId         String?
  approver           Employee?       @relation("RegularisationApprover", fields: [approverId], references: [id], onDelete: SetNull)
  decidedAt          DateTime?
  decidedBy          String?
  decisionNote       String?         @db.Text
  /// Link to the corrected AttendanceRecord row created on approval (BL-026).
  correctedRecordId  String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  /// Optimistic concurrency token (BL-034).
  version            Int             @default(0)

  correctedRecord    AttendanceRecord[] @relation("AttendanceCorrection")

  @@index([employeeId, date])
  @@index([approverId, status])
  @@index([status, routedTo])
  @@map("regularisation_requests")
}

/// Counter table for generating R-YYYY-NNNN codes — mirrors LeaveCodeCounter.
model RegCodeCounter {
  year    Int @id
  lastSeq Int @default(0)

  @@map("reg_code_counters")
}

/// Tracks monthly late counts for BL-028 deduction logic.
/// UNIQUE (employeeId, year, month) ensures idempotent upserts.
model AttendanceLateLedger {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation("EmployeeLateLedger", fields: [employeeId], references: [id], onDelete: Cascade)
  year       Int
  /// 1-12 calendar month.
  month      Int
  /// Running count of late marks this employee has in this year/month.
  count      Int      @default(0)

  @@unique([employeeId, year, month])
  @@map("attendance_late_ledger")
}

/// Holiday calendar. BL-026: holidays are identified via this table.
/// Admin replaces the calendar per year via PUT /config/holidays.
model Holiday {
  id    String   @id @default(cuid())
  year  Int
  date  DateTime @db.Date
  name  String   @db.VarChar(120)

  @@unique([year, date])
  @@index([date])
  @@map("holidays")
}

// ── Phase 4 — Payroll Processing ─────────────────────────────────────────────

/// BL-034: run lifecycle status.
/// Draft → Review → Finalised → (Reversed via a new reversal run record)
enum PayrollRunStatusDb {
  Draft
  Review
  Finalised
  Reversed
}

/// Mirrors PayrollRunStatusDb — payslips track the same lifecycle.
/// Reversal payslip records carry Reversed; originals stay Finalised (BL-031 / BL-032).
enum PayslipStatusDb {
  Draft
  Review
  Finalised
  Reversed
}

/// Payroll run. One per month per origination (original has reversalOfRunId=NULL;
/// reversal records have reversalOfRunId set to the source).
/// BL-034: UNIQUE (month, year, reversalOfRunId) allows original + reversal to coexist.
model PayrollRun {
  id              String             @id @default(cuid())
  /// RUN-YYYY-MM for originals; RUN-YYYY-MM-R<n> for reversal records.
  code            String             @unique
  month           Int                // 1–12
  year            Int
  status          PayrollRunStatusDb @default(Review)
  workingDays     Int
  periodStart     DateTime           @db.Date
  periodEnd       DateTime           @db.Date
  initiatedBy     String
  initiator       Employee           @relation("PayrollInitiator", fields: [initiatedBy], references: [id])
  finalisedBy     String?
  finaliser       Employee?          @relation("PayrollFinaliser", fields: [finalisedBy], references: [id])
  finalisedAt     DateTime?
  reversedBy      String?
  reverser        Employee?          @relation("PayrollReverser", fields: [reversedBy], references: [id])
  reversedAt      DateTime?
  reversalReason  String?            @db.Text
  /// Points to the original run when this is a reversal record. Null on originals.
  reversalOfRunId String?
  reversalOf      PayrollRun?        @relation("PayrollReversal", fields: [reversalOfRunId], references: [id])
  reversalRuns    PayrollRun[]       @relation("PayrollReversal")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  /// Optimistic concurrency token (BL-034).
  version         Int                @default(0)

  payslips        Payslip[]

  /// BL-034: original (NULL reversalOfRunId) is unique per month+year;
  /// multiple reversal records per month+year are allowed (n can increment).
  @@unique([month, year, reversalOfRunId])
  @@index([year, status])
  @@map("payroll_runs")
}

/// Payslip. One per employee per run. Immutable once Finalised (BL-031).
/// Reversal creates new rows; originals are never modified (BL-032).
model Payslip {
  id                   String          @id @default(cuid())
  /// P-YYYY-MM-NNNN — globally unique across all payslips.
  code                 String          @unique
  runId                String
  run                  PayrollRun      @relation(fields: [runId], references: [id])
  employeeId           String
  employee             Employee        @relation("EmployeePayslips", fields: [employeeId], references: [id])
  month                Int
  year                 Int
  status               PayslipStatusDb @default(Review)
  periodStart          DateTime        @db.Date
  periodEnd            DateTime        @db.Date
  workingDays          Int
  /// Days actually worked — used for BL-036 proration.
  daysWorked           Int
  /// Loss of pay days (BL-035).
  lopDays              Int             @default(0)
  /// Snapshot of the active salary structure (BL-030).
  basicPaise           Int
  allowancesPaise      Int
  /// Pro-rated gross for this period (BL-036).
  grossPaise           Int
  /// LOP deduction paise (BL-035).
  lopDeductionPaise    Int             @default(0)
  /// Reference tax = gross × standardRate (BL-036a).
  referenceTaxPaise    Int             @default(0)
  /// Final tax — editable by PO until run is Finalised (BL-036a).
  finalTaxPaise        Int             @default(0)
  /// Other deductions (PF, etc.) — zero in v1.
  otherDeductionsPaise Int             @default(0)
  /// Net pay = gross − lop − finalTax − other; never negative (BL-035).
  netPayPaise          Int
  finalisedAt          DateTime?
  /// Set on reversal payslips — points to the original payslip (BL-032).
  reversalOfPayslipId  String?
  reversalOfPayslip    Payslip?        @relation("PayslipReversal", fields: [reversalOfPayslipId], references: [id])
  reversalPayslips     Payslip[]       @relation("PayslipReversal")
  /// Set on original payslip when a reversal row exists.
  reversedByPayslipId  String?         @unique
  reversedByPayslip    Payslip?        @relation("PayslipReversedBy", fields: [reversedByPayslipId], references: [id])
  reversedByPayslipRef Payslip[]       @relation("PayslipReversedBy")
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  /// Optimistic concurrency token.
  version              Int             @default(0)

  @@index([employeeId, year, month])
  @@index([runId])
  @@index([status])
  @@map("payslips")
}

/// Counter table for generating RUN and Payslip codes.
/// kind: 'run' for RUN-YYYY-MM codes, 'payslip' for P-YYYY-MM-NNNN codes.
/// Indexed on (year, month, kind) — each combination holds its own sequence.
model PayrollCodeCounter {
  id      String @id @default(cuid())
  year    Int
  month   Int
  kind    String // 'run' | 'payslip'
  lastSeq Int    @default(0)

  @@unique([year, month, kind])
  @@map("payroll_code_counters")
}

/// Idempotency-Key store (SEC-004-P3 close-out).
/// One row per (userId, key). TTL: 24 h — cleanup cron deletes stale rows.
model IdempotencyKey {
  id           String   @id @default(cuid())
  userId       String
  user         Employee @relation("EmployeeIdempotencyKeys", fields: [userId], references: [id], onDelete: Cascade)
  key          String
  path         String
  status       Int
  responseBody Json
  createdAt    DateTime @default(now())

  @@unique([userId, key])
  @@index([userId, key])
  @@map("idempotency_keys")
}

// ── Phase 5 — Performance Reviews ────────────────────────────────────────────

/// BL-041: lifecycle of a performance cycle.
/// Enum values match the DB storage (no hyphens); mapped to contract enum at boundary.
enum CycleStatusDb {
  Open
  SelfReview
  ManagerReview
  Closed
}

/// Goal outcome — set by Manager (BL-038). Pending until rated.
enum GoalOutcomeDb {
  Met
  Partial
  Missed
  Pending
}

/// Performance cycle. One per fiscal half (H1 = Apr–Sep, H2 = Oct–Mar).
/// Code format: C-YYYY-H1 or C-YYYY-H2 (unique, derived from fyStart).
model PerformanceCycle {
  id                   String         @id @default(cuid())
  /// C-YYYY-H1 or C-YYYY-H2 — unique per fiscal half year
  code                 String         @unique
  fyStart              DateTime       @db.Date
  fyEnd                DateTime       @db.Date
  status               CycleStatusDb  @default(Open)
  selfReviewDeadline   DateTime       @db.Date
  managerReviewDeadline DateTime      @db.Date
  closedAt             DateTime?
  closedBy             String?
  closedByEmployee     Employee?      @relation("CycleClosedBy", fields: [closedBy], references: [id], onDelete: SetNull)
  createdBy            String
  createdByEmployee    Employee       @relation("CycleCreatedBy", fields: [createdBy], references: [id])
  /// Count of participants (excludes mid-cycle joiners — BL-037)
  participants         Int            @default(0)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  /// Optimistic concurrency token (BL-034)
  version              Int            @default(0)

  reviews              PerformanceReview[]

  @@index([status])
  @@index([fyStart])
  @@map("performance_cycles")
}

// ── Phase 6 — Notifications ──────────────────────────────────────────────────

/// Category enum — mirrors NotificationCategorySchema in @nexora/contracts/notifications.
/// Stored without hyphens; mapped at the application boundary.
enum NotificationCategoryDb {
  Leave
  Attendance
  Payroll
  Performance
  Status
  Configuration
  Auth
  System
}

/// In-app notification feed. BL-043: system-generated only (no public POST).
/// BL-044: every query MUST filter recipientId = user.id.
/// BL-045: archived after NOTIFICATION_RETENTION_DAYS (default 90) by a daily cron.
/// BL-046: in-app only — no email/SMS/push integration.
model Notification {
  id           String                  @id @default(cuid())
  recipientId  String
  recipient    Employee                @relation("EmployeeNotifications", fields: [recipientId], references: [id], onDelete: Cascade)
  category     NotificationCategoryDb
  /// ≤ 120 chars — enforced at the application layer before insert
  title        String                  @db.VarChar(120)
  /// ≤ 600 chars — plain text only (BL-046)
  body         String                  @db.VarChar(600)
  /// Deep link to the originating record, e.g. /employee/leave/L-2026-0118
  link         String?
  unread       Boolean                 @default(true)
  /// References the audit_log row that produced this notification (BL-047 link)
  auditLogId   String?
  createdAt    DateTime                @default(now())

  /// BL-044: unread feed sorted by newest first
  @@index([recipientId, unread])
  /// Cursor-pagination / feed queries
  @@index([recipientId, createdAt(sort: Desc)])
  /// Retention sweep — daily cron deletes rows older than retentionDays (BL-045)
  @@index([createdAt])
  @@map("notifications")
}

/// Performance review. One per employee per cycle.
/// BL-042: when a manager is reassigned mid-cycle, previousManagerId captures the
/// old manager so the audit retains both.
model PerformanceReview {
  id                   String         @id @default(cuid())
  cycleId              String
  cycle                PerformanceCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  employeeId           String
  employee             Employee       @relation("ReviewEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  /// BL-042: current manager; may change mid-cycle via reassign-manager endpoint.
  managerId            String?
  manager              Employee?      @relation("ReviewManager", fields: [managerId], references: [id], onDelete: SetNull)
  /// BL-042: previous manager captured on reassignment so both appear in the audit.
  previousManagerId    String?
  previousManager      Employee?      @relation("ReviewPreviousManager", fields: [previousManagerId], references: [id], onDelete: SetNull)
  /// 1–5; editable until selfReviewDeadline (BL-039)
  selfRating           Int?
  selfNote             String?        @db.Text
  selfSubmittedAt      DateTime?
  /// 1–5; sets managerOverrodeSelf if differs from selfRating (BL-040)
  managerRating        Int?
  managerNote          String?        @db.Text
  managerSubmittedAt   DateTime?
  /// BL-040: true when managerRating != selfRating
  managerOverrodeSelf  Boolean        @default(false)
  /// = managerRating once cycle Closes (BL-041)
  finalRating          Int?
  lockedAt             DateTime?
  /// BL-037: true for employees who joined after fyStart
  isMidCycleJoiner     Boolean        @default(false)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  /// Optimistic concurrency token
  version              Int            @default(0)

  goals                Goal[]

  @@unique([cycleId, employeeId])
  @@index([cycleId, managerId])
  @@index([employeeId])
  @@map("performance_reviews")
}

/// Goal within a review. Manager creates; Employee may propose (BL-038).
model Goal {
  id                   String         @id @default(cuid())
  reviewId             String
  review               PerformanceReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  text                 String         @db.Text
  outcome              GoalOutcomeDb  @default(Pending)
  /// BL-038: true when proposed by the Employee during self-review window
  proposedByEmployee   Boolean        @default(false)
  createdAt            DateTime       @default(now())
  /// Optimistic concurrency token
  version              Int            @default(0)

  @@index([reviewId])
  @@map("goals")
}
