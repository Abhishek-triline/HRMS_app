// Nexora HRMS — Prisma schema (Phase 0)
// BL-047 enforcement: REVOKE UPDATE, DELETE on audit_log runs as raw SQL
// after migration (see migration script comment).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  Employee
  Manager
  PayrollOfficer
  Admin
}

/// BL-022: employment type drives leave quotas and proration rules.
enum EmploymentType {
  Permanent
  Contract
  Intern
  Probation
}

/// Reason stored on ReportingManagerHistory rows when a row is closed.
enum HistoryReason {
  Initial
  Reassigned
  Exited
}

/// BL-006: Active / OnNotice / Exited are Admin-controlled.
/// OnLeave is system-set on leave approval start, reverted on end.
/// Inactive is the pre-first-login state.
enum EmployeeStatus {
  Active
  OnNotice
  Exited
  OnLeave
  Inactive
}

enum TokenPurpose {
  FirstLogin
  ResetPassword
}

// ── Tables ───────────────────────────────────────────────────────────────────

/// Core employee record. BL-008: code is EMP-YYYY-NNNN and never reused.
model Employee {
  id                String         @id @default(cuid())
  /// BL-008 — unique, never reused, generated transactionally per year
  code              String         @unique
  email             String         @unique
  /// stored as first+last or full name
  name              String
  passwordHash      String
  role              Role
  status            EmployeeStatus @default(Inactive)
  /// Employment type drives leave quotas and proration (BL-022a)
  employmentType    EmploymentType @default(Permanent)
  department        String?
  designation       String?
  reportingManagerId String?
  reportingManager  Employee?      @relation("EmployeeManager", fields: [reportingManagerId], references: [id])
  reports           Employee[]     @relation("EmployeeManager")
  /// The most recent prior manager id — fast lookup for past-team queries (BL-022a)
  previousReportingManagerId String?
  joinDate          DateTime       @db.Date
  exitDate          DateTime?      @db.Date
  /// UC-FL-01: forces password reset on first login
  mustResetPassword Boolean        @default(false)
  /// Optimistic concurrency token (BL-034 applies to all mutable resources)
  version           Int            @default(0)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  sessions              Session[]
  passwordResetTokens   PasswordResetToken[]
  loginAttempts         LoginAttempt[]
  auditActorEntries     AuditLog[]           @relation("AuditActor")
  salaryStructures      SalaryStructure[]
  reportingManagerHistory ReportingManagerHistory[] @relation("EmployeeHistory")
  managedHistories        ReportingManagerHistory[] @relation("ManagerHistory")

  @@index([email])
  @@index([reportingManagerId])
  @@index([previousReportingManagerId])
  @@map("employees")
}

/// Salary structure history. One row per change; active = latest effectiveFrom <= today.
/// BL-030: salary edits apply from the next payroll run only; old payslips are immutable.
model SalaryStructure {
  id              String   @id @default(cuid())
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  basicPaise      Int      /// stored as integer paise to avoid float drift
  allowancesPaise Int      /// sum of HRA + special + transport, etc.
  effectiveFrom   DateTime @db.Date
  createdAt       DateTime @default(now())
  /// Optimistic concurrency token
  version         Int      @default(0)

  @@index([employeeId, effectiveFrom(sort: Desc)])
  @@map("salary_structures")
}

/// Audit trail for reporting-manager assignments. BL-007: never deleted.
/// Insert Initial on employee creation; close row and insert new row on reassign.
model ReportingManagerHistory {
  id         String        @id @default(cuid())
  employeeId String
  employee   Employee      @relation("EmployeeHistory", fields: [employeeId], references: [id], onDelete: Cascade)
  managerId  String?
  manager    Employee?     @relation("ManagerHistory", fields: [managerId], references: [id], onDelete: SetNull)
  fromDate   DateTime      @db.Date
  /// null means currently open (this is the active assignment)
  toDate     DateTime?     @db.Date
  reason     HistoryReason
  createdAt  DateTime      @default(now())

  @@index([employeeId, fromDate(sort: Desc)])
  @@index([managerId, toDate])
  @@map("reporting_manager_history")
}

/// Session row. iron-session data maps to this.
/// Sliding expiry: 12 h default, 30 days if rememberMe.
model Session {
  id          String    @id @default(cuid())
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  ip          String?
  userAgent   String?   @db.Text
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  @@index([employeeId, expiresAt])
  @@map("sessions")
}

/// Single-use password reset / first-login token.
/// Raw token is sent over email; only the hash is stored (BL-047).
model PasswordResetToken {
  id          String       @id @default(cuid())
  employeeId  String
  employee    Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  tokenHash   String       @unique
  purpose     TokenPurpose
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime     @default(now())

  @@index([tokenHash])
  @@map("password_reset_tokens")
}

/// Login attempt log — used for 5-strikes-in-15-min lockout.
model LoginAttempt {
  id         String    @id @default(cuid())
  email      String
  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  ip         String
  success    Boolean
  createdAt  DateTime  @default(now())

  @@index([email])
  @@index([email, ip, createdAt])
  @@map("login_attempts")
}

/// Append-only audit log. BL-047 / BL-048.
/// DB enforces append-only via REVOKE UPDATE, DELETE (see migration).
/// id is a ULID (generated application-side for monotonic ordering).
model AuditLog {
  id          String   @id // ULID generated by application
  actorId     String?
  actor       Employee? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  actorRole   String
  actorIp     String?
  action      String   // e.g. "auth.login.success"
  targetType  String?
  targetId    String?
  module      String
  before      Json?
  after       Json?
  createdAt   DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@index([targetType, targetId])
  @@map("audit_log")
}

/// System configuration (A-19 and related). Key-value store.
/// Seeded with all configurable defaults on first run.
model Configuration {
  key       String   @id
  value     Json
  updatedBy String?
  updatedAt DateTime @updatedAt

  @@map("configuration")
}
