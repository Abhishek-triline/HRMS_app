# Nexora HRMS — environment template
# Copy to .env and fill in. Never commit a real .env.

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="mysql://root:Password%40123@localhost:3306/nexora_hrms"

# ── API server ───────────────────────────────────────────────────────────────
API_PORT=4000
API_BASE_URL="http://localhost:4000/api/v1"
NODE_ENV=development
LOG_LEVEL=info
# Where the JSONL log file lands. Relative paths resolve against apps/api/.
# Set LOG_TO_FILE=false to disable the file sink (stdout-only).
LOG_FILE="logs/api.log"
LOG_TO_FILE=true

# ── Web app ──────────────────────────────────────────────────────────────────
WEB_PORT=3000
WEB_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000/api/v1"

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGIN="http://localhost:3000"

# ── Session ──────────────────────────────────────────────────────────────────
# REQUIRED. Generate with: openssl rand -hex 32
# The API refuses to start if this is missing, shorter than 32 chars, or set
# to the placeholder string "REPLACE_ME".
SESSION_SECRET="REPLACE_ME"
SESSION_COOKIE_NAME="nx_session"

# ── Email (dev: filesystem stub; prod: SMTP) ─────────────────────────────────
MAIL_TRANSPORT="filesystem"          # filesystem | smtp
MAIL_FROM="Nexora HRMS <no-reply@triline.in>"
MAIL_DIR="/tmp/mail"                 # used when MAIL_TRANSPORT=filesystem
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""

# ── Locale / timezone ────────────────────────────────────────────────────────
TZ="Asia/Kolkata"
LOCALE="en-IN"

# ── Default admin (seed) ─────────────────────────────────────────────────────
SEED_ADMIN_EMAIL="admin@triline.in"
SEED_ADMIN_PASSWORD="admin@123"

# ── Auth tuning ──────────────────────────────────────────────────────────────
LOGIN_LOCKOUT_THRESHOLD=5
LOGIN_LOCKOUT_MINUTES=15
SESSION_TTL_HOURS=12
SESSION_REMEMBER_ME_DAYS=30
PASSWORD_RESET_TTL_MINUTES=30
