# tooling
.eslintcache

# Playwright — local runtime artefacts (HTML reports, trace.zip /
# video / screenshot output, .last-run.json, and the storageState
# snapshots produced by the auth fixture). All regenerated on every
# run; never commit.
playwright-report/
test-results/
apps/web/e2e/.auth/

# Prisma
apps/api/prisma/migrations/.tmp/

# API runtime logs (JSONL — viewable via .claude/view-api-log.sh)
apps/api/logs/

# dev mail stub (BL email delivery in dev)
/tmp/mail/

# Claude Code — runtime agent logs (project-scoped, generated per machine).
# settings.json, agents/, log-agent.sh, and view-log.sh stay tracked so the
# team shares the hook configuration; only the runtime log artefacts are local.
.claude/agents.log
.claude/agents.txt
.claude/settings.local.json

# Schema v2 refactor — legacy migrations kept locally for reference only
apps/api/prisma/migrations.legacy_v1/
