{
  "name": "@nexora/contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared zod schemas and TypeScript types — the canonical API contract for Nexora HRMS.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./auth": "./src/auth.ts",
    "./errors": "./src/errors.ts",
    "./common": "./src/common.ts",
    "./employees": "./src/employees.ts",
    "./leave": "./src/leave.ts",
    "./attendance": "./src/attendance.ts",
    "./payroll": "./src/payroll.ts",
    "./performance": "./src/performance.ts",
    "./notifications": "./src/notifications.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "echo \"(contracts: lint covered by typecheck)\""
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
