{
  "name": "@nexora/contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared zod schemas and TypeScript types — the canonical API contract for Nexora HRMS.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".":              { "types": "./dist/index.d.ts",         "default": "./dist/index.js" },
    "./auth":         { "types": "./dist/auth.d.ts",          "default": "./dist/auth.js" },
    "./errors":       { "types": "./dist/errors.d.ts",        "default": "./dist/errors.js" },
    "./common":       { "types": "./dist/common.d.ts",        "default": "./dist/common.js" },
    "./employees":    { "types": "./dist/employees.d.ts",     "default": "./dist/employees.js" },
    "./leave":        { "types": "./dist/leave.d.ts",         "default": "./dist/leave.js" },
    "./attendance":   { "types": "./dist/attendance.d.ts",    "default": "./dist/attendance.js" },
    "./payroll":      { "types": "./dist/payroll.d.ts",       "default": "./dist/payroll.js" },
    "./performance":  { "types": "./dist/performance.d.ts",   "default": "./dist/performance.js" },
    "./notifications":{ "types": "./dist/notifications.d.ts", "default": "./dist/notifications.js" },
    "./audit":        { "types": "./dist/audit.d.ts",         "default": "./dist/audit.js" },
    "./configuration":{ "types": "./dist/configuration.d.ts", "default": "./dist/configuration.js" }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"(contracts: lint covered by typecheck)\""
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
